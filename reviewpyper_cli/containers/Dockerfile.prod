FROM node:18-alpine AS build

WORKDIR /app

ARG BUILD_DIR=build

COPY reviewpyper_cli/frontend/package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY reviewpyper_cli/frontend/ ./
RUN npm run build

FROM nginx:1.27-alpine

ARG BUILD_DIR=build

COPY reviewpyper_cli/containers/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/${BUILD_DIR} /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
